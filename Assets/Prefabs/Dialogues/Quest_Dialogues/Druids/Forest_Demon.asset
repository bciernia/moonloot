  translationSets:
  - counter: 18
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Forest demon
    - id: 1
      language: en
      text: Do you want fight?
    - id: 2
      language: en
      text: Yes
    - id: 3
      language: en
      text: No
    - id: 4
      language: en
      text: 'Jest git wariacie

'
    - id: 5
      language: en
      text: Co
    - id: 6
      language: en
      text: "Co\u015B potrzeba wariacie?"
    - id: 7
      language: en
      text: "Tak, musze cie zniszczy\u0107."
    - id: 8
      language: en
      text: Nie, jest wszystko w pyte.
    - id: 9
      language: en
      text: I want to be your ally
    - id: 10
      language: en
      text: Meadow must be clear. DIE!!!
    - id: 11
      language: en
      text: How are you, my friend?
    - id: 12
      language: en
      text: Sorry, I have to destroy you!
    - id: 13
      language: en
      text: Everything's fine. I wanted to smell you, little flower.
    - id: 14
      language: en
      text: Go on.
    - id: 15
      language: en
      text: Player
    - id: 16
      language: en
      text: Sniff, sniff... You smell like lilac and gooseberry blossom.
    - id: 17
      language: en
      text: I know, I rolled around in those bushes.
