  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 15
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Kaelen
    - id: 1
      language: en
      text: Shhh.... Shhh....
    - id: 2
      language: en
      text: Li
    - id: 3
      language: en
      text: "Li\u015B\u0107..... U"
    - id: 4
      language: en
      text: "Li\u015B\u0107... U\u015Bmiech... Nie zwierz\u0119... "
    - id: 5
      language: en
      text: 'Zzz... Zzz... '
    - id: 6
      language: en
      text: "dZi\u0119ki za pobudke!"
    - id: 7
      language: en
      text: Leaf... Liar...
    - id: 8
      language: en
      text: 'Thanks for waking me up! '
    - id: 9
      language: en
      text: I was locked in a nightmare, a black, strange land.
    - id: 10
      language: en
      text: For a moment I even thought Brisanna had called me, but it wasn't death.
    - id: 11
      language: en
      text: 'But it wasn''t a dream either. It was as if Kael''nor had trapped me
        in his domain, but then again, no. '
    - id: 12
      language: en
      text: I heard a voice, a dark, feminine voice.
    - id: 13
      language: en
      text: I don't remember anything else.
    - id: 14
      language: en
      text: I don't remember anything else. Thank you!
  - counter: 7
    languageCode: es
    translations:
