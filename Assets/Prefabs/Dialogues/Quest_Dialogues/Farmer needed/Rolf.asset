MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e5800231a05eaae43b00503881229245, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 28
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Player
    - id: 1
      language: en
      text: Good morning, sir! I found your ad saying you're looking for an employee?
    - id: 2
      language: en
      text: Rolf
    - id: 3
      language: en
      text: Welcome, my name is Rolf. Yes, I'm looking for someone who has some muscles...
        Have you ever worked on farm?
    - id: 4
      language: en
      text: Yes, I was born on farm.
    - id: 5
      language: en
      text: No, but I'm not afraid. I am fast learner.
    - id: 6
      language: en
      text: Great, I just need someone to pick up the turnips and corn from my field.
        I can't do it anymore, and those nasty birds are about to peck it all up.
        Can you do this?
    - id: 7
      language: en
      text: Of course, I can help you.
    - id: 8
      language: en
      text: Well, I think it's not for me. Maybe later.
    - id: 9
      language: en
      text: Oh okay. I will wait here if you change your mind.
    - id: 10
      language: en
      text: So, can you help me with harvest?
    - id: 11
      language: en
      text: 'Good, take this key, open the gate and pick up corn and turnip from
        the field. Then come to me, bring me this and I will give you reward.  '
    - id: 12
      language: en
      text: I need 10 cobs of corn and 10 turnips.
    - id: 13
      language: en
      text: Do you have my crops?
    - id: 14
      language: en
      text: T
    - id: 15
      language: en
      text: F
    - id: 16
      language: en
      text: Here is corn.
    - id: 17
      language: en
      text: Here is turnip.
    - id: 18
      language: en
      text: Not yet.
    - id: 19
      language: en
      text: Okay, do it as fast as you can.
    - id: 20
      language: en
      text: My crops! Thank you!
    - id: 21
      language: en
      text: Thank you for your help! I hope you will come in next year.
    - id: 22
      language: en
      text: I needed corn for a salad, fantastic!
    - id: 23
      language: en
      text: My crops! Good job, thank you very much. Here is your reward.
    - id: 24
      language: en
      text: Turnips are best served warm. I'll make myself some soup.
    - id: 25
      language: en
      text: Great, I just need someone to pick up the turnips and corn from my field.
        I can't do it anymore, and those damn weeds that are just waiting to bite
        you. Can you do this?
    - id: 26
      language: en
      text: Okay, well...
    - id: 27
      language: en
      text: In fact, knowledge of farming is the least necessary.
