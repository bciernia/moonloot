%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &-797009195445016873
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e5800231a05eaae43b00503881229245, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 20
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Rolf
    - id: 1
      language: en
      text: 'Hey, who are you?! '
    - id: 2
      language: en
      text: Player
    - id: 3
      language: en
      text: Relax, I heard you were robbed. I'm looking for that thief.
    - id: 4
      language: en
      text: He robbed my cornfield. Most of what was growing. Good thing I chased
        him away in time.
    - id: 5
      language: en
      text: I saw him running towards the warehouse, but it was dark and I don't
        know where he went. You can ask the bartender about the warehouse. He has
        a key there.
    - id: 6
      language: en
      text: What do you want to know?
    - id: 7
      language: en
      text: Tell me what happened
    - id: 8
      language: en
      text: What did he look like?
    - id: 9
      language: en
      text: Okay, I will look for him.
    - id: 10
      language: en
      text: Dark skin color, like a thief's...
    - id: 11
      language: en
      text: ...black bandana on the head...
    - id: 12
      language: en
      text: ...and it smelled terrible
    - id: 13
      language: en
      text: I found this bastard.
    - id: 14
      language: en
      text: Great news!
    - id: 15
      language: en
      text: Did he have my corn?
    - id: 16
      language: en
      text: Unfortunately not.
    - id: 17
      language: en
      text: It's good that you came to town.
    - id: 18
      language: en
      text: Come back next year, I bet you've never eaten corn like this.
    - id: 19
      language: en
      text: Okay, I will find him.
