        audioClip: {fileID: 0}
        audioClipFile: 
        audioAssetID: 0
    - rid: 5422256016260333780
      type: {class: ConversationItem, ns: EasyTalk.Nodes.Common, asm: games.okitoki.EasyTalk}
      data:
        text: Then you can talk to Bartender or Meredith, they have some quests for
          you.
        audioClip: {fileID: 0}
        audioClipFile: 
        audioAssetID: 0
    - rid: 5422256016260333781
      type: {class: ConversationItem, ns: EasyTalk.Nodes.Common, asm: games.okitoki.EasyTalk}
      data:
        text: You can also go on town arena, and try your fighting skills.
