  - counter: 15
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Alchemist
    - id: 1
      language: en
      text: Hello! What do you want?
    - id: 3
      language: en
      text: Have we met already?
    - id: 4
      language: en
      text: Nothing, bye!
    - id: 5
      language: en
      text: Great thanks.
    - id: 6
      language: en
      text: Maybe, i don't know. Do you have any other questions?
    - id: 7
      language: en
      text: I want new quest!
    - id: 8
      language: en
      text: Ok, take it! Good luck!
    - id: 9
      language: en
      text: How are you?
    - id: 10
      language: en
      text: I will do my best!
    - id: 11
      language: en
      text: It's not enough for me!
    - id: 12
      language: en
      text: So you want second task?
    - id: 13
      language: en
      text: Nah, one will be enough
    - id: 14
      language: en
      text: It's should be enough for now. Come later for new adventures!
