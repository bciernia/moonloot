  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e5800231a05eaae43b00503881229245, type: 3}
  m_Name: Translation Library
  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 26
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Greg
    - id: 1
      language: en
      text: "They say a dragon was seen in the south... but that\u2019s probably
        just old Mirk after too much mead."
    - id: 2
      language: en
      text: "There\u2019s a tavern three days from here where no one speaks \u2014
        only hand signs and grunts. Best ale I\u2019ve ever had."
    - id: 3
      language: en
      text: or just fall on your face.
    - id: 4
      language: en
      text: "They say if you walk around the old oak tree backwards at midnight,
        you\u2019ll see your future... "
    - id: 5
      language: en
      text: "Somewhere past the marshes, there\u2019s a tree that sings lullabies.
        Creepy ones."
    - id: 6
      language: en
      text: My cousin swears he saw a knight riding a giant boar. Either that, or
        he drank too much mushroom wine.
    - id: 7
      language: en
      text: Any rumours?
    - id: 8
      language: en
      text: See you!
    - id: 9
      language: en
      text: Kaelen
    - id: 10
      language: en
      text: test
    - id: 11
      language: en
      text: Hey! Are you Jovan? His wife told me he has white hat and red jacket!
    - id: 12
      language: en
      text: 'I''m not him! I just look like him because this is a demo version of
        game! I saw him leave through the south gate and then head west. '
    - id: 13
      language: en
      text: 'I''m not him! I just look like him because this is a demo version of
        game! I saw him leave through the south gate and then head east. '
    - id: 14
      language: en
      text: 'I''m not him! I just look like him because this is a demo version of
        game! I saw him leave through the south gate and then head east to forest. '
    - id: 15
      language: en
      text: I'm looking for your chief. Have yo u
    - id: 16
      language: en
      text: I'm looking for your chief. Do you know anything?
    - id: 17
      language: en
      text: "I shouldn\u2019t be saying this\u2026 but I saw the chief meeting strangers
        outside the village walls."
    - id: 18
      language: en
      text: "They weren\u2019t merchants, that much I\u2019m sure. Looked more like
        bandits than traders."
    - id: 19
      language: en
      text: That's all i know.
    - id: 20
      language: en
      text: I'm looking for village chief. Do you know something about his missing?
    - id: 21
      language: en
      text: Bryce
    - id: 22
      language: en
      text: 'I''m looking for village chief. Do you know something about his missing?
        I''m looking for village chief. Do you know something about his missing?
        I''m looking for village chief. Do you know something about his missing? '
    - id: 23
      language: en
      text: 'I''m looking for village chief. Do you know something about his missing? '
    - id: 24
      language: en
      text: Test flag
    - id: 25
      language: en
      text: 'I''m looking for village chief. Do you know something about his missing?
        I''m looking for village chief. Do you know something about his missing? '
