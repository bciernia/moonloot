--- !u!114 &-8329394831597146268
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e5800231a05eaae43b00503881229245, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 15
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Jovan
    - id: 1
      language: en
      text: Thank you for help!
    - id: 2
      language: en
      text: Thank you for help! I have some gold, so please take it.
    - id: 3
      language: en
      text: Your wife is looking for you. She promised me reward, so keep your gold.
    - id: 4
      language: en
      text: Your wife is looking for you.
    - id: 5
      language: en
      text: Thank you for rescue. I will go to village soon. Let's meet at the inn.
    - id: 6
      language: en
      text: Thank you for help! I have some shards, so please take it.
    - id: 7
      language: en
      text: '*Take the shards*'
    - id: 8
      language: en
      text: Take the 30 shards
    - id: 9
      language: en
      text: Your wife is looking for you. She promised me reward, so keep your money.
    - id: 10
      language: en
      text: Oh, thank you, you're welcome, it's just that Brisanna hasn't decided
        to summon you to her presence yet.
    - id: 11
      language: en
      text: Thank you for help! I have some lunars, so please take it.
    - id: 12
      language: en
      text: 'Oh, thank you, you''re welcome, it''s just that Brisanna hasn''t decided
        to summon you to her presence yet. '
    - id: 13
      language: en
      text: Take the 30 lunars
    - id: 14
      language: en
      text: Thank you for rescue. I will go to village soon. Let's meet at the inn.
        There is my wife Meredith, she will give you reward. Thank you one more time!
