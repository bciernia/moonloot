  m_Name: Translation Library
  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 21
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Player
    - id: 1
      language: en
      text: Who are you? I'm looking for Hendrik.
    - id: 2
      language: en
      text: Hendrik
    - id: 3
      language: en
      text: Hey, yes, yes, that's me.
    - id: 4
      language: en
      text: Do you have key to cell? It's closed.
    - id: 5
      language: en
      text: Bandit chief
    - id: 6
      language: en
      text: 'We knew that you will come here. '
    - id: 7
      language: en
      text: My scouts saw you in pass. I have an offer for you.
    - id: 8
      language: en
      text: 'My scouts saw you in pass. I have an offer for you. '
    - id: 9
      language: en
      text: My scouts saw you on the mountain pass. I should kill you for killing
        my people.
    - id: 10
      language: en
      text: But...
    - id: 11
      language: en
      text: Give me the key or I'll kill you like I killed your people.
    - id: 12
      language: en
      text: But what?
    - id: 13
      language: en
      text: 'Easy, believe me, working for me will pay off for you. '
    - id: 14
      language: en
      text: But I have proposition for you. Leave Hendrik here and take this 1000
        lunars.
    - id: 15
      language: en
      text: Easy, believe me, working for me will pay off for you. Just take lunars,
        and go out from
    - id: 16
      language: en
      text: Never, I am here to rescue him.
    - id: 17
      language: en
      text: Okay, give me money and I will leave.
    - id: 18
      language: en
      text: Kill him!
    - id: 19
      language: en
      text: Thank you for help. Just open cell and I will get back to village.
    - id: 20
      language: en
      text: Come to my house in Satbury, I will reward you.
