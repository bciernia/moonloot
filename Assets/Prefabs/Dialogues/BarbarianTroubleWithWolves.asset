  originalLanguage: en
  translationSets:
  - counter: 16
    languageCode: en
    translations:
    - id: 0
      language: en
      text: Player
    - id: 1
      language: en
      text: Hey, i've heard that you may have some problem with wolves in forest?
    - id: 2
      language: en
      text: Scared barbarian
    - id: 3
      language: en
      text: "\rI have no problem with anyone"
    - id: 4
      language: en
      text: Okay, sorry for bothering your mighty head
    - id: 5
      language: en
      text: Are you sure?
    - id: 6
      language: en
      text: 'Okay, maybe I have small problem with those tiny creatures.

'
    - id: 7
      language: en
      text: 'Kill those monsters! There are 3 wolves. '
    - id: 8
      language: en
      text: They are looking like zombies sometimes, but it might be a bug.
    - id: 9
      language: en
      text: Test
    - id: 10
      language: en
      text: Did you killed them?
    - id: 11
      language: en
      text: Leave me alone...
    - id: 12
      language: en
      text: I'm done with fighting.
    - id: 13
      language: en
      text: Jimbo
    - id: 14
      language: en
      text: Did you complete the task?
    - id: 15
      language: en
      text: 'Please, leave me...

'
