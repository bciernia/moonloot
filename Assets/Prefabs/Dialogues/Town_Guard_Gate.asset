%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &-8352814661138820509
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e5800231a05eaae43b00503881229245, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  originalLanguage: en
  translationSets:
  - counter: 18
    languageCode: en
    translations:
    - id: 0
      language: en
      text: "The Light of Kareth never rests\u2014and neither do we."
    - id: 1
      language: en
      text: Guard
    - id: 2
      language: en
      text: "Kareth blesses the brave\u2014and you look like one who\u2019s known
        His gaze."
    - id: 3
      language: en
      text: Every night is a trial of courage. Dawn is the reward.
    - id: 4
      language: en
      text: "Justice doesn\u2019t sleep, even if we barely stand."
    - id: 5
      language: en
      text: May Kareth guide our hands to justice...
    - id: 6
      language: en
      text: ...May His Light pierce every shadow...
    - id: 7
      language: en
      text: ...And may our blades never tremble before the innocent.
    - id: 8
      language: en
      text: What's new?
    - id: 9
      language: en
      text: Have you seen Jovan? Man in white hat and red jacket?
    - id: 10
      language: en
      text: Goodbye
    - id: 11
      language: en
      text: I saw him leaving yesterday and heading this way.
    - id: 12
      language: en
      text: He turned west, but I heard wolves there too, so if he's still alive,
        I'd be surprised.
    - id: 13
      language: en
      text: Okay, thank you for the information.
    - id: 14
      language: en
      text: Haven't you checked where it is?
    - id: 15
      language: en
      text: Sir, where are we going to go at night when we have to be on guard here?
    - id: 16
      language: en
      text: If anyone goes into the forest, they do so at their own risk.
    - id: 17
      language: en
      text: Good luck!
